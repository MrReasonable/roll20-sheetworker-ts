{
  "name": "roll20-sheetworker-ts",
  "version": "1.2.0",
  "description": "TypeScript Types for Roll20 SheetWorker scripts.",
  "keywords": [
    "Typescript",
    "Roll20",
    "SheetWorker"
  ],
  "homepage": "https://github.com/MrReasonable/roll20-sheetworker-ts#readme",
  "bugs": {
    "url": "https://github.com/MrReasonable/roll20-sheetworker-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrReasonable/roll20-sheetworker-ts.git"
  },
  "license": "MIT",
  "author": "MrReasonable",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:types": "tsc --noEmit -p test-d/tsconfig.json",
    "build": "tsc",
    "prepublishOnly": "pnpm run build"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./global": {
      "types": "./dist/global.d.ts",
      "default": "./dist/global.js"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "eslint": "^9.25.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1"
  }
}
